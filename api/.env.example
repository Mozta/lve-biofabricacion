# Copia a .env (o exporta estas variables antes de correr uvicorn).
# El backend las lee del entorno; no hay carga automática de .env.

# Puerto serial del XIAO ESP32-C3. Ejemplos:
#   macOS:  /dev/tty.usbmodem1101
#   Linux:  /dev/ttyACM0
#   Windows: COM3
LVE_PORT=

# Fuerza el enlace simulado aunque haya un puerto (útil para desarrollar sin hardware).
# LVE_MOCK=1

# Ruta alternativa del archivo SQLite (por defecto api/lve.db).
# LVE_DB=/ruta/a/lve.db
